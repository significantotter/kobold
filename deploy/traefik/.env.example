# Domain for Traefik to manage
DOMAIN=kobold.tools

# Email for Let's Encrypt certificate notifications
ACME_EMAIL=your-email@example.com

# Basic auth for Traefik dashboard (generate with: htpasswd -nB admin)
# Example: admin:$2y$05$...
# To generate: docker run --rm httpd:2.4-alpine htpasswd -nB admin
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$changeme
