# Kobold Web - Environment Variables
# Copy this to stack.env and fill in values
# In Portainer, these go in the stack's "Environment variables" section

# === Required ===

# PostgreSQL connection string (your Supabase prod DB)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Secret for signing session cookies (generate a strong random value)
# Example: openssl rand -hex 32
API_SECRET=change-me-to-a-random-secret

# Public-facing URL of the web app (used for OAuth redirect_uri)
API_BASE_URL=https://kobold.tools

# Frontend URL (used for post-OAuth redirects back to the SPA)
FRONTEND_BASE_URL=https://kobold.tools

# === Discord OAuth ===

DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=

# === Wanderer's Guide (optional) ===

WANDERERS_GUIDE_API_KEY=
WANDERERS_GUIDE_OAUTH_BASE_URL=
