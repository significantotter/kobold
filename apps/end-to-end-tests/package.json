	},
	"devDependencies": {
		"@kobold/config": "workspace:*",
		"@kobold/db": "workspace:*",
		"@playwright/test": "^1.52.0",
		"@types/node": "^25.0.3",
		"kysely": "^0.28.9",
		"typescript": "^5.9.3"
	}
}
