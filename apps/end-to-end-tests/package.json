{
	"name": "@kobold/end-to-end-tests",
	"version": "1.0.0",
	"description": "Playwright end-to-end tests for the Kobold Discord bot",
	"license": "MIT",
	"private": true,
	"type": "module",
	"scripts": {
		"test": "playwright test",
