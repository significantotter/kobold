{
	"name": "@kobold/web",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
		"dev:client": "vite",
		"dev:server": "tsx watch server/index.ts",
		"build": "pnpm build:client && pnpm build:server",
		"build:client": "vite build",
		"build:server": "tsc -p tsconfig.server.json",
		"start": "node dist/server/index.js",
		"preview": "vite preview"
	},
	"dependencies": {
		"@hono/node-server": "^1.13.7",
		"@kobold/config": "workspace:*",
		"@kobold/db": "workspace:*",
		"@kobold/documentation": "workspace:*",
		"@kobold/schema": "workspace:*",
		"@kobold/sheet": "workspace:*",
		"@orpc/client": "^1.13.13",
		"@orpc/server": "^1.0.0",
		"@primevue/themes": "^4.5.4",
		"@skyra/discord-components-core": "^4.0.2",
		"@vueuse/core": "^14.1.0",
		"discord-api-types": "^0.38.37",
		"hono": "^4.6.14",
		"lodash": "^4.17.21",
		"markdown-it": "^14.1.0",
		"pinia": "^3.0.4",
		"primeicons": "^7.0.0",
		"primevue": "^4.5.4",
		"vue": "^3.5.13",
		"vue-router": "^4.5.0",
		"vue-use-active-scroll": "^1.1.3",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"@tailwindcss/typography": "^0.5.19",
		"@types/lodash": "^4.17.21",
		"@types/markdown-it": "^14.1.2",
		"@types/node": "^25.0.3",
		"@vitejs/plugin-vue": "^5.2.1",
		"autoprefixer": "^10.4.20",
		"concurrently": "^9.1.2",
		"postcss": "^8.4.49",
		"sass-embedded": "^1.97.1",
		"tailwindcss": "^3.4.17",
		"tailwindcss-primeui": "^0.6.1",
		"tsx": "^4.19.2",
		"typescript": "^5.9.3",
		"vite": "^6.0.7",
		"vue-tsc": "^3.2.0"
	}
}
